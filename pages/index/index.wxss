.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 0;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  filter: blur(1px) saturate(0.9);
}

.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  background: 
    linear-gradient(180deg, 
      rgba(0,0,0,0.3) 0%, 
      rgba(0,0,0,0.1) 30%, 
      rgba(0,0,0,0.2) 70%, 
      rgba(0,0,0,0.6) 100%
    ),
    radial-gradient(ellipse at center, 
      rgba(255,255,255,0.05) 0%, 
      transparent 70%
    );
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
}

.content-wrapper {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100%;
  padding: 40rpx;
  box-sizing: border-box;
}

.merit-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
}

.merit-label {
  font-size: 28rpx;
  color: #8b8b8b;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}

.merit-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #5a5a5a;
  letter-spacing: 2rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.wooden-fish-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
}

.animation-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: visible;
}

.wooden-fish-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wooden-stick-wrapper {
  position: absolute;
  top: 58rpx;
  right: 58rpx;
  width: 150rpx;
  height: 150rpx;
  transform: rotate(45deg);
  transform-origin: bottom right;
  transition: transform 0.05s ease-out;
  z-index: 10;
}

.wooden-stick-wrapper.hit {
  transform: rotate(15deg) translateX(-20rpx) translateY(20rpx);
}

.wooden-stick-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.merit-add-animation {
  position: absolute;
  font-size: 48rpx;
  font-weight: bold;
  color: #d4a574;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.15);
  pointer-events: none;
  animation: floatUp 1.2s ease-out forwards;
  white-space: nowrap;
  transform: translateX(-50%);
}

@keyframes floatUp {
  0% {
    opacity: 1;
    transform: translateY(50rpx) scale(1);
  }
  20% {
    opacity: 1;
    transform: translateY(30rpx) scale(1.1);
  }
  100% {
    opacity: 0;
    transform: translateY(-250rpx) scale(0.8);
  }
}

.wooden-fish-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s ease;
  cursor: pointer;
}

.wooden-fish-wrapper:active {
  transform: scale(0.95);
}

.wooden-fish-wrapper, .wooden-stick-wrapper {
  -webkit-tap-highlight-color: transparent;
  tap-highlight-color: transparent;
}

.wooden-fish-wrapper.shake {
  animation: shake 0.15s ease-in-out;
}

@keyframes shake {
  0%, 100% {
    transform: scale(1) rotate(0deg);
  }
  25% {
    transform: scale(0.95) rotate(-3deg);
  }
  50% {
    transform: scale(0.98) rotate(2deg);
  }
  75% {
    transform: scale(0.96) rotate(-1deg);
  }
}

.wooden-fish-image {
  width: 400rpx;
  height: 400rpx;
  max-width: 70vw;
  max-height: 70vh;
  object-fit: contain;
  filter: drop-shadow(4rpx 4rpx 8rpx rgba(0, 0, 0, 0.15));
}

.settings-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
  transition: opacity 0.2s;
}

.settings-button:active {
  opacity: 0.3;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.settings-text {
  font-size: 28rpx;
  color: #8b8b8b;
}

.keyword-selector {
  width: 100%;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.selector-label {
  display: block;
  font-size: 24rpx;
  color: #555;
  text-align: center;
  margin-left: 30rpx;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.keyword-scroll {
  width: 100vw;
  height: 80rpx;
  white-space: nowrap;
  overflow-x: scroll;
  -webkit-overflow-scrolling: touch;
  display: block;
  padding-left: 40rpx;
  box-sizing: border-box;
}

.keyword-list {
  display: inline-flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 0 30rpx;
  width: max-content;
}

.keyword-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: #f0f0f0;
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.keyword-item:active {
  transform: scale(0.95);
}

.keyword-item.active {
  background: linear-gradient(135deg, #d4a574 0%, #c49464 100%);
  color: white;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.4);
}

.action-buttons {
  display: flex;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.share-button, .settings-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  margin-bottom: 40rpx;
  border-radius: 30rpx;
  opacity: 0.6;
  background: linear-gradient(135deg, #d4a574 0%, #c49464 100%);
  transition: opacity 0.2s;
}

.share-button:active, .settings-button:active {
  opacity: 0.3;
}

.share-button.cyber-share {
  background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
  opacity: 1;
}

.share-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.share-text {
  font-size: 28rpx;
  color: #fff;
}

.settings-text {
  font-size: 28rpx;
  color: #fff;
}

.settings-button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  margin-bottom: 40rpx;
  border-radius: 30rpx;
  opacity: 0.6;
  background: linear-gradient(135deg, #d4a574 0%, #c49464 100%);
  transition: opacity 0.2s;
}

.settings-button:active {
  opacity: 0.3;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.settings-text {
  font-size: 28rpx;
  color: #666;
}

.share-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
}

.hidden-share-btn {
  position: fixed;
  top: -9999px;
  left: -9999px;
  width: 0;
  height: 0;
  opacity: 0;
  border: none;
  background: transparent;
}

.container.classic .bg-image,
.container.cyber .bg-image,
.container.overdrive .bg-image {
  display: block;
}

@keyframes backgroundFlash {
  0%, 100% {
    background: linear-gradient(180deg, #0D0D0D 0%, #1a0000 100%);
  }
  50% {
    background: linear-gradient(180deg, #1a0505 0%, #2a0a0a 100%);
  }
}

.cyber-label {
  color: #666;
}

.cyber-value {
  color: #39FF14;
  text-shadow: 0 0 20rpx rgba(57, 255, 20, 0.5),
               0 0 40rpx rgba(57, 255, 20, 0.3);
  font-family: 'Courier New', monospace;
}

.cps-display {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.cps-value {
  font-size: 24rpx;
  color: #888;
  font-family: 'Courier New', monospace;
}

.overdrive-badge {
  font-size: 24rpx;
  color: #ff3333;
  font-weight: bold;
  animation: blink 0.3s infinite;
  text-shadow: 0 0 10rpx rgba(255, 51, 51, 0.8);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.cyber-text {
  color: #39FF14;
  text-shadow: 0 0 10rpx rgba(57, 255, 20, 0.8),
               2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
  font-family: 'Courier New', monospace;
}

.merit-add-animation.overdrive-text {
  color: #ff3333;
  text-shadow: 0 0 20rpx rgba(255, 51, 51, 0.8),
               0 0 40rpx rgba(255, 51, 51, 0.5),
               3rpx 3rpx 6rpx rgba(0, 0, 0, 0.8);
  animation: explode 0.8s ease-out forwards;
  font-weight: 900;
}

@keyframes explode {
  0% {
    opacity: 1;
    transform: translate(0, 0) scale(1.5) rotate(0deg);
  }
  100% {
    opacity: 0;
    transform: translate(var(--explode-x), var(--explode-y)) scale(0.3) rotate(calc(var(--explode-angle) * 1deg));
  }
}

.wooden-fish-wrapper.overdrive-fish {
  animation: glitchShake 0.1s infinite;
  filter: drop-shadow(0 0 20rpx rgba(255, 51, 51, 0.8));
}

@keyframes glitchShake {
  0%, 100% {
    transform: translate(0, 0) scale(1);
    filter: drop-shadow(0 0 20rpx rgba(255, 51, 51, 0.8));
  }
  25% {
    transform: translate(-5rpx, 5rpx) scale(0.98);
    filter: drop-shadow(2rpx 0 0 rgba(0, 255, 255, 0.8)) drop-shadow(-2rpx 0 0 rgba(255, 0, 255, 0.8));
  }
  50% {
    transform: translate(5rpx, -5rpx) scale(1.02);
    filter: drop-shadow(-2rpx 0 0 rgba(0, 255, 255, 0.8)) drop-shadow(2rpx 0 0 rgba(255, 0, 255, 0.8));
  }
  75% {
    transform: translate(-3rpx, -3rpx) scale(0.99);
    filter: drop-shadow(0 0 30rpx rgba(255, 51, 51, 1));
  }
}

.wooden-stick-wrapper.overdrive-stick {
  animation: glitchRotate 0.15s infinite;
}

@keyframes glitchRotate {
  0%, 100% {
    transform: rotate(15deg) translateX(-20rpx) translateY(20rpx);
  }
  33% {
    transform: rotate(12deg) translateX(-15rpx) translateY(25rpx);
  }
  66% {
    transform: rotate(18deg) translateX(-25rpx) translateY(15rpx);
  }
}

.warning-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  animation: warningPulse 0.5s infinite;
}

@keyframes warningPulse {
  0%, 100% {
    opacity: 0.8;
  }
  50% {
    opacity: 0.3;
  }
}

.warning-text {
  font-size: 32rpx;
  color: #ff3333;
  font-weight: bold;
  text-shadow: 0 0 20rpx rgba(255, 51, 51, 0.8);
  animation: warningBlink 0.3s infinite;
}

@keyframes warningBlink {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(0.95);
  }
}

.cyber-keyword {
  background: #1a1a1a;
  border: 1rpx solid #333;
  color: #888;
}

.cyber-keyword.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
  color: #0D0D0D;
  font-weight: bold;
  border-color: #ff6b6b;
  box-shadow: 0 0 20rpx rgba(255, 107, 107, 0.5),
              0 0 40rpx rgba(254, 202, 87, 0.3);
}

.container.shake-light {
  animation: shakeLight 0.1s ease-in-out;
}

.container.shake-medium {
  animation: shakeMedium 0.15s ease-in-out;
}

.container.shake-heavy {
  animation: shakeHeavy 0.2s ease-in-out;
}

.container.shake-overdrive {
  animation: shakeOverdrive 0.08s ease-in-out infinite;
}

@keyframes shakeLight {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-2rpx); }
  75% { transform: translateX(2rpx); }
}

@keyframes shakeMedium {
  0%, 100% { transform: translateX(0) translateY(0); }
  20% { transform: translateX(-3rpx) translateY(2rpx); }
  40% { transform: translateX(3rpx) translateY(-2rpx); }
  60% { transform: translateX(-2rpx) translateY(-1rpx); }
  80% { transform: translateX(2rpx) translateY(1rpx); }
}

@keyframes shakeHeavy {
  0%, 100% { transform: translateX(0) translateY(0); }
  10% { transform: translateX(-5rpx) translateY(3rpx); }
  30% { transform: translateX(5rpx) translateY(-3rpx); }
  50% { transform: translateX(-4rpx) translateY(-2rpx); }
  70% { transform: translateX(4rpx) translateY(2rpx); }
  90% { transform: translateX(-2rpx) translateY(1rpx); }
}

@keyframes shakeOverdrive {
  0%, 100% { transform: translateX(0) translateY(0) rotate(0deg); }
  20% { transform: translateX(-6rpx) translateY(4rpx) rotate(-1deg); }
  40% { transform: translateX(6rpx) translateY(-4rpx) rotate(1deg); }
  60% { transform: translateX(-4rpx) translateY(-3rpx) rotate(-0.5deg); }
  80% { transform: translateX(4rpx) translateY(3rpx) rotate(0.5deg); }
}


