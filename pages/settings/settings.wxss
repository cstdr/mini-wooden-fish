.settings-container {
  padding: 40rpx;
  background: linear-gradient(180deg, #f8f6f1 0%, #ebe8e3 100%);
  min-height: 100vh;
}

.settings-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  color: #8b8b8b;
  letter-spacing: 4rpx;
  margin-bottom: 30rpx;
  font-weight: 500;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.theme-picker {
  display: flex;
  gap: 20rpx;
}

.theme-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  transition: all 0.3s;
  min-width: 120rpx;
}

.theme-option:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.theme-option.active {
  background: linear-gradient(135deg, #d4a574 0%, #c49464 100%);
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.4);
}

.theme-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.theme-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.theme-option.active .theme-name {
  color: white;
  font-weight: bold;
}

.increment-picker {
  display: flex;
  gap: 20rpx;
}

.increment-option {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.2s;
}

.increment-option.active {
  background: #d4a574;
  color: white;
  font-weight: bold;
}

.increment-option:active {
  opacity: 0.8;
}

.danger-section {
  background: #fff5f5;
}

.danger-item {
  border-bottom: none;
}

.danger-label {
  color: #e74c3c;
}

.danger-hint {
  color: #e74c3c;
  font-size: 36rpx;
}

.danger-item:active {
  opacity: 0.6;
}

.app-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  opacity: 0.5;
}

.app-name {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.app-version {
  font-size: 24rpx;
  color: #999;
}
